  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "7ca3158f-bcab-4c89-8fd5-9f98fb9bf973"
      },
      "text": "customers_schema_v1\r\n| summarize CustomerCount = count() by City\r\n| order by CustomerCount desc",
      "id": "9caead0b-9183-48ca-bcd4-6d9720104d92",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "7ca3158f-bcab-4c89-8fd5-9f98fb9bf973"
      },
      "text": "\r\nOrders\r\n| extend IngestTime = ingestion_time()\r\n| where IngestTime > ago(1d)\r\n| summarize TotalOrders = count()\r\n\r\n\r\n",
      "id": "1980e581-0a1b-4fa7-b8ff-4fc5ec4138f7",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "7ca3158f-bcab-4c89-8fd5-9f98fb9bf973"
      },
      "text": "Orders\r\n|extend ingest_time = ingestion_time()\r\n| where ingest_time > ago(1d)\r\n| summarize OrderCount = count() by product\r\n| order by OrderCount desc",
      "id": "a77c30c1-5b3a-43e0-98a5-ac76c7be7fd4",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "7ca3158f-bcab-4c89-8fd5-9f98fb9bf973"
      },
      "text": "transactions\r\n| extend ingestion_time = ingestion_time()\r\n| where ingestion_time > ago(1h)\r\n| summarize\r\n    Total = count(),\r\n    Success = countif(transaction_status == \"SUCCESS\"),\r\n    Failed = countif(transaction_status == \"FAILED\"),\r\n    SuccessRate = 100.0 * countif(transaction_status == \"SUCCESS\") / count()",
      "id": "caf40416-b79a-47ac-9ae0-e3e437e568c9",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "7ca3158f-bcab-4c89-8fd5-9f98fb9bf973"
      },
      "text": "transactions\r\n| extend ingestion_time = ingestion_time()\r\n| where ingestion_time > ago(1d)\r\n| summarize Count = count() by payment_method\r\n| order by Count desc",
      "id": "ff99096e-0958-4d83-a9e0-142709f5cc3f",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "7ca3158f-bcab-4c89-8fd5-9f98fb9bf973"
      },
      "text": "transactions\r\n| extend ingestion_time = ingestion_time()\r\n| where ingestion_time > ago(1d)\r\n| summarize Amount = sum(transaction_amount) by bin(ingestion_time, 30m)\r\n| order by ingestion_time asc",
      "id": "1bf4e5e0-f826-407a-85d0-01e18848a935",
      "usedVariables": []
    }
  ]
